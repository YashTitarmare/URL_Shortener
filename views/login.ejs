<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-indigo-600 to-purple-600 min-h-screen flex items-center justify-center">

<div class="container mt-5 bg-white p-8 rounded-2xl shadow-2xl w-full max-w-md">
    
    <h1 class="mb-4 text-3xl font-bold text-center text-indigo-600">
        Login
    </h1>

    <form method="post" action="/users/login" class="space-y-5">

        <div class="mb-3">
            <label class="form-label block text-gray-700 font-medium mb-2">
                Email
            </label>
            <input 
                type="text" 
                required 
                name="email"
                class="form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500"
            >
        </div>

        <div class="mb-3">
            <label class="form-label block text-gray-700 font-medium mb-2">
                Password
            </label>
            <input 
                type="password" 
                required 
                name="password"
                class="form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500"
            >
        </div>

        <button 
            type="submit" 
            class="btn btn-primary w-full bg-indigo-600 text-white py-2 rounded-lg font-semibold hover:bg-indigo-700 transition duration-300"
        >
            Login
        </button>

    </form>
</div>

</body>
</html>